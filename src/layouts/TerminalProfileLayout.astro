---
import Layout from '@/layouts/Layout.astro'
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PostNavigation from '@/components/PostNavigation.astro'
import ScrollToTop from '@/components/ScrollToTop.astro'
import TableOfContents from '@/components/TableOfContents.astro'
import { badgeVariants } from '@/components/ui/badge'
import { Separator } from '@/components/ui/separator'
import Link from '@/components/Link.astro'
import { formatDate, readingTime } from '@/lib/utils'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import type { MarkdownHeading } from 'astro'
import TerminalWindow from '@/components/me/TerminalWindow.astro'
import CommandLine from '@/components/me/CommandLine.astro'
import SkillMeter from '@/components/me/SkillMeter.astro'
import BootSequence from '@/components/me/BootSequence.tsx'
import TerminalPrompt from '@/components/me/TerminalPrompt.tsx'
import {
  PROFILE,
  BOOT_LINES,
  SKILLS,
  ARSENAL,
  ACHIEVEMENTS,
  ROADMAP,
  MISSION,
  SOCIALS,
} from '@/lib/profile'
import '@/styles/terminal.css'

type PostLink = { slug: string; data: { title: string } } | null

interface Props {
  title: string
  description: string
  image?: string
  date: Date
  body: string
  headings: MarkdownHeading[]
  tags?: string[]
  owner?: { avatar: string; name: string }
  prevPost: PostLink
  nextPost: PostLink
}
const {
  title,
  description,
  image,
  date,
  body,
  headings,
  tags = [],
  owner,
  prevPost,
  nextPost,
} = Astro.props
---

<Layout title={title} description={description} image={image}>
  <section
    class="terminal-root grid grid-cols-[minmax(0px,1fr)_min(768px,100%)_minmax(0px,1fr)] gap-y-6 *:px-4"
  >
    <Breadcrumbs
      items={[
        { href: '/me', label: 'me', icon: 'lucide:archive' },
        { label: title, icon: 'lucide:terminal' },
      ]}
      class="col-start-2"
    />

    <!-- standard post header (parity with other pages) -->
    <header class="col-start-2 flex flex-col gap-y-4 text-center">
      <h1
        class="glitch text-3xl font-bold tracking-tight sm:text-4xl"
        data-text={title}
      >
        {title}
      </h1>
      <div
        class="flex flex-wrap items-center justify-center gap-2 text-sm text-muted-foreground"
      >
        {
          owner && (
            <>
              <span class="flex items-center gap-x-1.5">
                <Image
                  src={owner.avatar}
                  alt={owner.name}
                  width={24}
                  height={24}
                  class="rounded-full"
                />
                <Link href={`/me/${owner.name}`} underline class="text-foreground">
                  {owner.name}
                </Link>
              </span>
              <Separator orientation="vertical" className="h-4" />
            </>
          )
        }
        <span>{formatDate(date)}</span>
        <Separator orientation="vertical" className="h-4" />
        <span>{readingTime(body)}</span>
      </div>
      {
        tags.length > 0 && (
          <div class="flex flex-wrap justify-center gap-2">
            {tags.map((tag) => (
              <a href={`/tags/${tag}`} class={badgeVariants({ variant: 'secondary' })}>
                <Icon name="lucide:hash" class="size-3 -translate-x-0.5" />
                {tag}
              </a>
            ))}
          </div>
        )
      }
    </header>

    <PostNavigation prevPost={prevPost} nextPost={nextPost} baseUrl="/me/" />

    {headings.length > 0 && <TableOfContents headings={headings} />}

    <!-- terminal body -->
    <div class="col-start-2">
      <TerminalWindow title={`${PROFILE.handle}@${PROFILE.host}: ~/profile`}>
        <BootSequence client:load lines={BOOT_LINES} />

        <CommandLine cmd="whoami">
          <p class="text-xs text-muted-foreground sm:text-sm">
            <span class="term-cyan">alias</span>={PROFILE.alias} · <span
              class="term-cyan">role</span
            >={PROFILE.role} · <span class="term-cyan">loc</span>={PROFILE.location}
            · <span class="term-cyan">status</span>={PROFILE.status}
          </p>
          <p class="mt-3 max-w-prose text-foreground/90">{PROFILE.summary}</p>
        </CommandLine>

        <CommandLine cmd="cat ./skills.json">
          <div class="grid gap-3 sm:grid-cols-2 sm:gap-x-8">
            {SKILLS.map((skill) => <SkillMeter skill={skill} />)}
          </div>
        </CommandLine>

        <CommandLine cmd="ls -la ./arsenal">
          <div class="grid gap-4 sm:grid-cols-3">
            {
              ARSENAL.map((group) => (
                <div>
                  <p class="mb-1.5 text-xs uppercase tracking-wider term-green">
                    ./{group.label}
                  </p>
                  <ul class="space-y-1">
                    {group.items.map((item) => (
                      <li class="text-foreground/90">
                        <span class="term-dim">›</span> {item}
                      </li>
                    ))}
                  </ul>
                </div>
              ))
            }
          </div>
        </CommandLine>

        <CommandLine cmd="git log --oneline">
          <ul class="space-y-1.5">
            {
              ACHIEVEMENTS.map((entry) => (
                <li class="flex gap-x-3">
                  <span class="term-amber">{entry.hash}</span>
                  <span class="text-foreground/90">{entry.msg}</span>
                </li>
              ))
            }
          </ul>
        </CommandLine>

        <CommandLine cmd="cat ./roadmap.md">
          <ul class="space-y-1.5">
            {
              ROADMAP.map((item) => (
                <li class="flex items-start gap-x-2">
                  <span class={item.done ? 'term-green' : 'term-dim'}>
                    [{item.done ? 'x' : ' '}]
                  </span>
                  <span
                    class={
                      item.done
                        ? 'text-muted-foreground line-through'
                        : 'text-foreground/90'
                    }
                  >
                    {item.text}
                  </span>
                </li>
              ))
            }
          </ul>
        </CommandLine>

        <CommandLine cmd="./mission --statement">
          <blockquote
            class="border-l-2 border-[hsl(var(--term-green))] pl-4 italic text-foreground/90"
          >
            {MISSION}
          </blockquote>
        </CommandLine>

        <!-- full original write-up (MDX body — feeds the ToC) -->
        <CommandLine cmd="cat ./full-writeup.md">
          <article
            class="prose prose-sm prose-neutral max-w-none dark:prose-invert prose-headings:term-green prose-a:!text-primary"
          >
            <slot />
          </article>
        </CommandLine>

        <CommandLine cmd="./shell">
          <TerminalPrompt
            client:visible
            user={PROFILE.handle}
            host={PROFILE.host}
            summary={PROFILE.summary}
            skills={SKILLS.map((s) => s.name)}
            socials={SOCIALS}
          />
        </CommandLine>
      </TerminalWindow>
    </div>

    <PostNavigation prevPost={prevPost} nextPost={nextPost} baseUrl="/me/" />
  </section>

  <ScrollToTop />
</Layout>
