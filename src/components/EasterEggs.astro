<script>
  if (!(window as any).__eggs) {
    ;(window as any).__eggs = true

    console.log(
      '%cPixelPulse',
      'color:#9ae66e;font-size:22px;font-weight:bold;text-shadow:0 0 10px #9ae66e',
    )
    console.log('%c// hello, friend.', 'color:#888;font-style:italic')
    console.log('%c↑ ↑ ↓ ↓ ← → ← → B A', 'color:#9ae66e')
    console.log('%cLMDtokyo@proton.me', 'color:#888')

    const QUOTES = [
      'Wake up, Neo… — The Matrix',
      'Hello, friend. — Mr. Robot',
      'The cake is a lie. — Portal',
      "Don't Panic. — The Hitchhiker's Guide to the Galaxy",
      'All those moments will be lost in time, like tears in rain. — Blade Runner',
      'The sky was the color of television, tuned to a dead channel. — Neuromancer',
      'It’s a UNIX system! I know this! — Jurassic Park',
      'The right man in the wrong place makes all the difference. — Half-Life 2',
      'I am the one who knocks. — Breaking Bad',
    ]

    const seq = [
      'ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown',
      'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight', 'b', 'a',
    ]
    let pos = 0

    document.addEventListener('keydown', (event) => {
      const key = event.key.length === 1 ? event.key.toLowerCase() : event.key
      if (key === seq[pos]) {
        pos += 1
        if (pos === seq.length) {
          pos = 0
          unlock()
        }
      } else {
        pos = key === seq[0] ? 1 : 0
      }
    })

    function unlock() {
      console.log('%cACCESS GRANTED', 'color:#9ae66e;font-size:16px;font-weight:bold')
      const quote = QUOTES[Math.floor(Math.random() * QUOTES.length)]
      toast(quote)
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        matrixRain()
      }
    }

    function toast(text: string) {
      const el = document.createElement('div')
      el.textContent = text
      el.style.cssText = [
        'position:fixed', 'left:50%', 'top:18%', 'transform:translateX(-50%)',
        'z-index:10000', 'max-width:90vw', 'padding:10px 18px',
        'font-family:monospace', 'font-size:14px', 'text-align:center',
        'color:#9ae66e', 'background:rgba(10,10,10,.85)',
        'border:1px solid rgba(154,230,110,.5)', 'border-radius:8px',
        'box-shadow:0 0 30px rgba(154,230,110,.25)',
        'opacity:0', 'transition:opacity .4s',
      ].join(';')
      document.body.appendChild(el)
      requestAnimationFrame(() => (el.style.opacity = '1'))
      setTimeout(() => {
        el.style.opacity = '0'
        setTimeout(() => el.remove(), 500)
      }, 4500)
    }

    function matrixRain() {
      const canvas = document.createElement('canvas')
      canvas.style.cssText =
        'position:fixed;inset:0;z-index:9998;pointer-events:none;transition:opacity 1s'
      document.body.appendChild(canvas)
      const ctx = canvas.getContext('2d')
      if (!ctx) return

      let width = (canvas.width = window.innerWidth)
      let height = (canvas.height = window.innerHeight)
      const glyphs = 'アイウエオカキクケコサシスセソ0123456789ABCDEF#$%@'
      const fontSize = 16
      let columns = Math.floor(width / fontSize)
      let drops = new Array(columns).fill(0).map(() => Math.random() * -50)

      const onResize = () => {
        width = canvas.width = window.innerWidth
        height = canvas.height = window.innerHeight
        columns = Math.floor(width / fontSize)
        drops = new Array(columns).fill(0).map(() => Math.random() * -50)
      }
      window.addEventListener('resize', onResize)

      const draw = () => {
        ctx.fillStyle = 'rgba(0,0,0,0.08)'
        ctx.fillRect(0, 0, width, height)
        ctx.fillStyle = '#9ae66e'
        ctx.font = `${fontSize}px monospace`
        for (let i = 0; i < drops.length; i++) {
          const char = glyphs[Math.floor(Math.random() * glyphs.length)]
          ctx.fillText(char, i * fontSize, drops[i] * fontSize)
          if (drops[i] * fontSize > height && Math.random() > 0.975) drops[i] = 0
          drops[i] += 1
        }
      }

      const timer = setInterval(draw, 45)
      setTimeout(() => {
        clearInterval(timer)
        canvas.style.opacity = '0'
        window.removeEventListener('resize', onResize)
        setTimeout(() => canvas.remove(), 1000)
      }, 6000)
    }
  }
</script>
