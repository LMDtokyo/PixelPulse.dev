---
import { ACCENT_CLASS, type Skill } from '@/lib/profile'

interface Props {
  skill: Skill
}
const { skill } = Astro.props
const accent = ACCENT_CLASS[skill.accent]
// 20-cell ASCII gauge
const filled = Math.round((skill.level / 100) * 20)
const bar = '█'.repeat(filled) + '░'.repeat(20 - filled)
---

<div class="grid grid-cols-[1fr_auto] items-center gap-x-3 gap-y-0.5">
  <span class="truncate text-foreground">{skill.name}</span>
  <span class={`tabular-nums text-xs ${accent}`}>{skill.level}%</span>
  <span
    class={`col-span-2 select-none overflow-hidden whitespace-nowrap font-mono text-xs sm:text-sm ${accent}`}
    aria-hidden="true"
  >
    [<span
      class="skill-meter inline-block origin-left"
      style={`animation-delay: ${skill.level * 4}ms`}>{bar}</span
    >]
  </span>
</div>
