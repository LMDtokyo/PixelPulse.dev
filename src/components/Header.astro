---
import Container from '@/components/Container.astro'
import Link from '@/components/Link.astro'
import MobileMenu from '@/components/ui/mobile-menu'
import { NAV_LINKS } from '@/consts'
import { PROFILE } from '@/lib/profile'
---

<header
  class="sticky top-0 z-20 border-b border-border bg-background/70 font-mono backdrop-blur"
>
  <Container>
    <div class="flex items-center justify-between gap-4 py-3 text-sm">
      <Link href="/" class="flex items-center whitespace-nowrap">
        <span class="text-muted-foreground">
          <span class="term-green">{PROFILE.handle}</span>@<span
            class="term-cyan">{PROFILE.host}</span
          >:<span class="text-primary">~</span>$
        </span>
        <span class="term-caret ml-1.5" aria-hidden="true"></span>
      </Link>

      <nav class="hidden items-center gap-x-4 sm:flex">
        {
          NAV_LINKS.map((item) => (
            <Link href={item.href} class="nav-cmd text-muted-foreground">
              <span class="text-primary/50">cd</span> {item.label}
            </Link>
          ))
        }
      </nav>

      <MobileMenu client:load transition:persist />
    </div>
  </Container>
</header>

<style>
  .nav-cmd {
    @apply transition-colors duration-200;
  }
  .nav-cmd:hover {
    color: hsl(var(--term-green));
  }
</style>
