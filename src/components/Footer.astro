---
import Container from '@/components/Container.astro'
import { SOCIAL_LINKS } from '@/consts'
import { PROFILE } from '@/lib/profile'

const year = new Date().getFullYear()
const toHref = (link: { href: string; label: string }) =>
  link.label === 'Email' ? `mailto:${link.href}` : link.href
---

<footer class="border-t border-border bg-background font-mono">
  <Container>
    <div class="py-12 text-center">
      <div
        class="glitch select-none text-5xl font-bold tracking-tighter sm:text-7xl"
        data-text="PixelPulse"
      >
        PixelPulse
      </div>
      <p class="mt-3 text-xs uppercase tracking-[0.3em] text-muted-foreground">
        frontend <span class="term-green">×</span> cybersecurity
      </p>

      <p class="mx-auto mt-6 max-w-md text-xs leading-relaxed text-muted-foreground/70">
        <span class="term-green">&gt;</span> Я пообещал наблюдать за ней и смирился с ношей ее будущего на своих плечах.
      </p>

      <div
        class="mt-8 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 border-t border-border pt-6 text-xs text-muted-foreground"
      >
        {
          SOCIAL_LINKS.map((link) => (
            <a href={toHref(link)} class="social-cmd">
              {link.label.toLowerCase()}
            </a>
          ))
        }
        <span class="text-muted-foreground/50">© {year} {PROFILE.alias}</span>
      </div>
    </div>
  </Container>
</footer>

<style>
  .social-cmd {
    @apply transition-colors duration-200;
  }
  .social-cmd:hover {
    color: hsl(var(--term-green));
  }
</style>
