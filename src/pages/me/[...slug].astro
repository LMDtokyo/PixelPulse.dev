---
import TerminalProfileLayout from '@/layouts/TerminalProfileLayout.astro'
import { getAdjacentPosts, sortByDate } from '@/lib/collections'
import { type CollectionEntry, getCollection } from 'astro:content'

export async function getStaticPaths() {
  const posts = sortByDate(await getCollection('me'))
  return posts.map((post) => ({ params: { slug: post.slug }, props: post }))
}
type Props = CollectionEntry<'me'>

const posts = sortByDate(await getCollection('me'))
const post = Astro.props
const { prev, next } = getAdjacentPosts(posts, post.slug)
const { Content, headings } = await post.render()
const ogImage = post.data.image?.src ?? '/static/1200x630.png'
---

<TerminalProfileLayout
  title={post.data.title}
  description={post.data.description}
  image={ogImage}
  cover={post.data.image}
  date={post.data.date}
  body={post.body}
  tags={post.data.tags ?? []}
  headings={headings}
  owner={post.data.owner}
  prevPost={prev}
  nextPost={next}
>
  <Content />
</TerminalProfileLayout>
