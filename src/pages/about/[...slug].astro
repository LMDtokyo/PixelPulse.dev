---
import PostLayout from '@/layouts/PostLayout.astro'
import { getAdjacentPosts, sortByDate } from '@/lib/collections'
import { type CollectionEntry, getCollection } from 'astro:content'

export async function getStaticPaths() {
  const posts = sortByDate(await getCollection('about'))
  return posts.map((post) => ({ params: { slug: post.slug }, props: post }))
}
type Props = CollectionEntry<'about'>

const posts = sortByDate(await getCollection('about'))
const post = Astro.props
const { prev, next } = getAdjacentPosts(posts, post.slug)
const { Content, headings } = await post.render()
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  parent={{ href: '/about', label: 'About' }}
  baseUrl="/about/"
  date={post.data.date}
  body={post.body}
  headings={headings}
  prevPost={prev}
  nextPost={next}
>
  <Content />
</PostLayout>
